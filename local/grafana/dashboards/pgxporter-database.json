          },
          "expr": "sum(rate(pg_stat_database_xact_rollback_total{job=~\"$job\", instance=~\"$instance\", datname=~\"$database\"}[$__rate_interval]))",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
