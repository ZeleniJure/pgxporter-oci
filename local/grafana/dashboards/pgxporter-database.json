    {
      "id": 9,
      "type": "timeseries",
      "title": "Effective concurrency by time category (PG 14+)",
      "description": "Seconds of work per second of wall-clock. 1.0 = one backend continuously busy in that category. idle-in-tx > 0 sustained is the canonical 'app forgot to COMMIT/ROLLBACK' shape.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(pg_stat_database_active_time_seconds_total{job=~\"$job\", instance=~\"$instance\", datname=~\"$database\"}[$__rate_interval]))",
          "legendFormat": "active (executing query)",
          "refId": "A",
          "instant": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(pg_stat_database_idle_in_transaction_time_seconds_total{job=~\"$job\", instance=~\"$instance\", datname=~\"$database\"}[$__rate_interval]))",
          "legendFormat": "idle in tx",
          "refId": "B",
          "instant": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(pg_stat_database_session_time_seconds_total{job=~\"$job\", instance=~\"$instance\", datname=~\"$database\"}[$__rate_interval]))",
          "legendFormat": "session (total connected)",
          "refId": "C",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
