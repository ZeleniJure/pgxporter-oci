# Sample environment for running the binary outside docker compose.
# Copy to .env and `set -a; source .env; set +a` before `go run .`.

# Postgres connection
PGX_HOST=localhost
PGX_PORT=5432
PGX_USER=exporter
PGX_DB=appdb

# Auth: set PGX_PASSWORD for password mode. Leave it unset and set
# AWS_REGION instead to use RDS IAM (production mode).
PGX_PASSWORD=exporter
# AWS_REGION=us-east-1

# HTTP
LISTEN_ADDR=:9187
